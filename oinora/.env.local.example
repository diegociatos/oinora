# =================================================
# Oi Nora · variáveis de ambiente
# =================================================
# Copie este arquivo para .env.local e preencha os valores reais.
# NUNCA commite .env.local (já está no .gitignore).
# No Netlify, configure essas mesmas variáveis em Site settings → Environment variables.
# =================================================

# --- Supabase ---
# https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Anthropic (Claude API) ---
# https://console.anthropic.com/settings/keys
# Necessário a partir do MVP 2 (triagem de CV, descrição de vaga, cálculo de risco)
ANTHROPIC_API_KEY=

# --- Voyage AI (embeddings semânticos) ---
# https://dash.voyageai.com/api-keys
# Necessário a partir do MVP 2 (match candidato-vaga, similaridade entre processos)
VOYAGE_API_KEY=

# --- Stripe (billing) ---
# https://dashboard.stripe.com/test/apikeys
# Necessário a partir do MVP 6 (Console Oi Nora + planos)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# --- Resend (emails transacionais) ---
# https://resend.com/api-keys
# Necessário a partir do MVP 1 (convites, magic link, notificações)
RESEND_API_KEY=re_...

# --- eSocial gateway (Pinhais ou Tagplus) ---
# Necessário a partir do MVP 4
ESOCIAL_GATEWAY_KEY=
ESOCIAL_GATEWAY_BASE_URL=

# --- Application ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Oi Nora
